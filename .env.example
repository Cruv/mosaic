# Mosaic — copy to .env and set HOST_IP. docker compose reads this automatically.

# REQUIRED: this box's LAN IP (e.g. 192.168.1.50). Advertised as the WebRTC ICE
# candidate and used by browsers to reach the WHEP media endpoint. Viewers and
# OBS must be able to reach it. `localhost` only works if you also browse from
# this same machine.
HOST_IP=192.168.1.50

# LinuxServer.io-style conventions (consistent with my other stacks).
PUID=1000
PGID=1000
TZ=America/Indiana/Indianapolis

# OBS publisher password. OBS "Bearer Token" field = streamer:<this>.
# Viewers need no token (read/playback is open on the LAN).
MEDIAMTX_PUBLISH_PASS=changeme

# Ports (defaults are fine for most setups).
MOSAIC_PORT=8080
MEDIAMTX_WEBRTC_PORT=8889
